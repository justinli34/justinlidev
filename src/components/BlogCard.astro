---
import styles from "./BlogCard.module.css";

type Props = {
  date: string;
  href: string;
  title: string;
};

const { date, href, title } = Astro.props;
---

<article>
  <a href={href} class={styles.card}>
    <div class={styles.header}>
      <h3 class={styles.title}>{title}</h3>
      <p class={styles.date}>{date}</p>
    </div>
  </a>
</article>
